# Copy to webhook.env and fill in. NEVER commit the filled-in file.
# See docs/license-webhook.md for details.

# --- Required ---
# Signing secret you set when creating the Lemon Squeezy webhook
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Ed25519 private key (PKCS#8 PEM). Either inline (use \n for newlines) ...
DEVWORK_LICENSE_PRIVATE_KEY=
# ... or a path to the PEM file (alternative to the inline var above)
# DEVWORK_LICENSE_PRIVATE_KEY_FILE=/run/secrets/devwork_private_key.pem

# Map your Lemon Squeezy product/variant IDs to tiers (JSON)
LICENSE_TIER_MAPPING={"proVariantIds":[],"teamVariantIds":[]}

# --- Optional ---
# Email delivery via Resend (omit both to return the key in the HTTP response)
RESEND_API_KEY=
LICENSE_EMAIL_FROM=dev-work <keys@yourdomain.com>
# LICENSE_EMAIL_SUBJECT=Your dev-work license key
# LICENSE_PRODUCT_NAME=dev-work

# License validity (years from purchase). Default 1.
# LICENSE_DURATION_YEARS=1
# Bind the key to the buyer email (default true).
# LICENSE_BIND_EMAIL=true
# Provider events that mint a key (comma-separated). Default order_created.
# LICENSE_ACCEPTED_EVENTS=order_created
# Port for the standalone server. Default 8787.
# PORT=8787
